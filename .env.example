# Qdrant Cloud
QDRANT_URL=https://ca3d0204-fdba-4172-a78e-b5dd1e6c7ae8.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=DDD
QDRANT_COLLECTION_NAME=medical_textbooks

# Local embeddings (BGE-M3, 1024-dim)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=DDD
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1

# Context-injected chunking (optional overrides)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
TEMP_UPLOAD_DIR=tmp_uploads

# Supabase
SUPABASE_URL=https://DDD.supabase.co
SUPABASE_SERVICE_KEY=DDD

# JWT Authentication
JWT_SECRET=DDD
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://mediragai.vercel.app

# Admin seed (only used on first startup)
SEED_ADMIN_USERNAME=DDD
SEED_ADMIN_PASSWORD=DDD
SEED_ADMIN_ROLE=maintainer

# Worker
WORKER_POLL_INTERVAL_SECONDS=5

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Retry (network-call resilience)
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_MAX_DELAY_SECONDS=30.0
