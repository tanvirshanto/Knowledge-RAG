# Qdrant Cloud
QDRANT_URL=https://ca3d0204-fdba-4172-a78e-b5dd1e6c7ae8.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=DDA
QDRANT_COLLECTION_NAME=medical_textbooks

# Local embeddings (BGE-M3, 1024-dim)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# Command Code Provider API (https://commandcode.ai/docs/provider-api)
COMMAND_CODE_API_KEY=SFS
COMMAND_CODE_BASE_URL=https://api.commandcode.ai/provider/v1
# Examples: deepseek/deepseek-v4-flash, deepseek/deepseek-v4-pro
COMMAND_CODE_MODEL=deepseek/deepseek-v4-pro
LLM_TEMPERATURE=0.1

# Context-injected chunking (optional overrides)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
TEMP_UPLOAD_DIR=tmp_uploads
